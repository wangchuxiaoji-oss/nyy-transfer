# 应用元信息
APP_NAME=nyy
APP_ENV=dev
APP_BASE_URL=http://127.0.0.1:8000
APP_LOG_LEVEL=INFO

# 后端服务
HOST=127.0.0.1
PORT=8000

# 数据库（异步）
DATABASE_URL=postgresql+asyncpg://nyy:nyy@127.0.0.1:5432/nyy
# Alembic 用的同步连接
DATABASE_SYNC_URL=postgresql+psycopg://nyy:nyy@127.0.0.1:5432/nyy

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# 安全
SECRET_KEY=change-me-please-32-bytes-minimum-secret
SESSION_COOKIE_NAME=nyy_session
CSRF_COOKIE_NAME=nyy_csrf

# 短码
SHORT_CODE_LENGTH=6

# 上传 / 配额
GUEST_MAX_FILE_BYTES=209715200
USER_MAX_FILE_BYTES=1073741824
GUEST_TTL_HOURS=24

# 豆包 file station
DOUBAO_FILE_STATION_BASE_URL=http://127.0.0.1:9190
DOUBAO_FILE_STATION_API_KEY=sk-local
DOUBAO_SESSION_FILE=/data/nyy/backend/.doubao_session.json

# Captcha（hCaptcha 测试 key）
HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# 邮件（Resend）
RESEND_API_KEY=
EMAIL_FROM=noreply@nyy.app
